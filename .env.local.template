# Google Analytics 4 Configuration
# Replace G-XXXXXXXXXX with your actual GA4 Measurement ID
# Find this in Google Analytics: Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Sundae Admin lead capture (Required for /api/cta/submit)
# The same MARKETING_LEAD_HMAC_SECRET must be set on sundae-backend.
LEAD_BACKEND=sundae
SUNDAE_BACKEND_URL=https://api.sundaetech.ai
MARKETING_LEAD_HMAC_SECRET=replace-with-shared-hex-secret

# Optional: self-serve scheduling for the Operations Diagnostic "Book deep-dive
# call" CTA. When set (e.g. a Cal.com / Calendly link), the booked-call
# confirmation shows a "Pick a time now" button (prefilled with name + email).
# Leave unset to keep the current behaviour (qualified lead forwarded to sales).
# NEXT_PUBLIC_BOOKING_URL=https://cal.com/sundae/deep-dive

# ClickUp CTA Integration (Legacy rollback only)
# Get your API token from: ClickUp > Settings > Apps > API Token
# Get your List ID from the ClickUp list URL: https://app.clickup.com/WORKSPACE_ID/v/li/LIST_ID
CLICKUP_API_TOKEN=your_clickup_api_token_here
CLICKUP_LIST_ID=your_clickup_list_id_here

# ClickUp Lead Information Custom Fields (Optional but Recommended)
# These map form fields to ClickUp custom fields for structured data
# Find custom field IDs in ClickUp: List Settings > Custom Fields > Click field > Copy field ID
CLICKUP_FIELD_FULL_NAME=
CLICKUP_FIELD_EMAIL=
CLICKUP_FIELD_COMPANY=
CLICKUP_FIELD_ROLE=
CLICKUP_FIELD_PHONE=
CLICKUP_FIELD_COUNTRY=
CLICKUP_FIELD_POS=
CLICKUP_FIELD_LOCATIONS=
CLICKUP_FIELD_MESSAGE=

# ClickUp Source/UTM Custom Fields (Optional - Legacy Support)
# These track where the lead came from
CLICKUP_CF_CTA_LABEL=
CLICKUP_CF_SOURCE_PAGE=
CLICKUP_CF_UTM_SOURCE=
CLICKUP_CF_UTM_MEDIUM=
CLICKUP_CF_UTM_CAMPAIGN=

# Google Sheets Fallback Storage (Optional but Recommended)
# Use Google Sheets as a reliable fallback for form submissions
# See GOOGLE_SHEETS_QUICKSTART.md for setup instructions
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Note: This file should be copied to .env.local and the actual values should be added
# .env.local is gitignored and will not be committed to the repository
